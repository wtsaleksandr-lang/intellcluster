# IntellCluster — Environment Variables
# Copy to .env and fill in your API keys

# LLM API Keys (at least one required; more judges = better output)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
XAI_API_KEY=xai-...

# Optional: aliases that also work
# GPT_API_KEY, CLAUDE_API_KEY, GEMINI_API_KEY, GROK_API_KEY

# Admin (for Synthesis admin panel)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SECRET_KEY=change-this-in-production

# Server
PORT=5000
DEBUG=false
COST_PROFILE=cheap
