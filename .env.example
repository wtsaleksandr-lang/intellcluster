# IntellCluster — Environment Variables
# Copy to .env and fill in your keys

# ─── LLM API Keys (at least one required) ───
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
XAI_API_KEY=xai-...

# (aliases also accepted: GPT_API_KEY, CLAUDE_API_KEY, GEMINI_API_KEY, GROK_API_KEY)

# ─── Admin ───
ADMIN_USERNAME=admin@intellcluster.com
ADMIN_PASSWORD=admin123
ADMIN_SECRET_KEY=change-this-to-random-32-char-string

# ─── Server ───
PORT=5000
DEBUG=false
COST_PROFILE=cheap

# ─── Rate limiting ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30

# ─── Stripe (fill in when ready to charge) ───
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — create products in Stripe Dashboard, paste IDs here
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_CREDITS_5=
STRIPE_PRICE_CREDITS_15=
STRIPE_PRICE_CREDITS_30=

# ─── Email (optional — for waitlist confirmations) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@intellcluster.com

# ─── Analytics (optional — Plausible) ───
PLAUSIBLE_DOMAIN=
